{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lesson-in-game/pack-schema",
  "title": "Lesson in Game content pack",
  "description": "One validated lesson content pack. Shells read only the primitives they support. A pack MUST have reviewStatus 'approved' before the runner will launch it live (the teacher review gate).",
  "type": "object",
  "required": ["packId", "subject", "grade", "language", "objective", "bloom", "primitives", "reviewStatus", "items"],
  "properties": {
    "packId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$", "description": "Slug, e.g. 'photosynthesis-g8-001'" },
    "title": { "type": "string", "description": "Human title shown to teacher and on the cast screen" },
    "subject": { "type": "string" },
    "grade": { "type": ["integer", "string"], "description": "School grade/form, e.g. 8 or '8-A'" },
    "language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$", "description": "ISO language of the content and student UI, e.g. 'uk', 'en'" },
    "objective": { "type": "string", "description": "The teacher's learning objective in their own words" },
    "bloom": { "enum": ["remember", "understand", "apply", "analyze", "evaluate", "create"] },
    "primitives": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["recall", "classify", "sequence", "locate", "estimate", "argue", "simulate"] }
    },
    "reviewStatus": { "enum": ["draft", "approved"], "description": "Runner refuses to launch 'draft' packs live (preview is allowed)" },
    "approvedAt": { "type": "string", "description": "ISO timestamp set by the review-pack skill on approval" },
    "createdAt": { "type": "string" },
    "reflectionPrompt": { "type": "string", "description": "Optional override for the end-of-session reflection question (RECIPE rule: one is always shown)" },
    "items": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/$defs/item" }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "required": ["id", "primitive", "prompt", "difficulty"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,32}$" },
        "primitive": { "enum": ["recall", "classify", "sequence", "locate", "estimate", "argue", "simulate"] },
        "prompt": { "type": "string", "minLength": 3 },
        "difficulty": { "type": "integer", "minimum": 1, "maximum": 5, "description": "Drives adaptive selection: the engine walks toward the class's competence edge" },
        "explanation": { "type": "string", "description": "Shown to every student at round review. Required for recall/estimate (immediate-feedback rule)" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Subtopic tags; the misconception map in the report groups by these" }
      },
      "allOf": [
        {
          "if": { "properties": { "primitive": { "const": "recall" } } },
          "then": {
            "required": ["options", "answer", "explanation"],
            "properties": {
              "options": { "type": "array", "minItems": 2, "maxItems": 6, "items": { "type": "string" } },
              "answer": { "type": "integer", "minimum": 0, "description": "Index into options" }
            }
          }
        },
        {
          "if": { "properties": { "primitive": { "const": "estimate" } } },
          "then": {
            "required": ["numericAnswer", "tolerance", "explanation"],
            "properties": {
              "numericAnswer": { "type": "number" },
              "tolerance": { "type": "number", "exclusiveMinimum": 0, "description": "Full credit within ±tolerance; half credit within ±2×tolerance" },
              "unit": { "type": "string" },
              "min": { "type": "number", "description": "Optional input hint lower bound" },
              "max": { "type": "number", "description": "Optional input hint upper bound" }
            }
          }
        },
        {
          "if": { "properties": { "primitive": { "const": "classify" } } },
          "then": {
            "required": ["elements", "categories", "mapping"],
            "properties": {
              "elements": { "type": "array", "minItems": 2, "items": { "type": "string" } },
              "categories": { "type": "array", "minItems": 2, "items": { "type": "string" } },
              "mapping": { "type": "array", "items": { "type": "integer", "minimum": 0 }, "description": "mapping[i] = category index of elements[i]" }
            }
          }
        },
        {
          "if": { "properties": { "primitive": { "const": "sequence" } } },
          "then": {
            "required": ["elements", "answer"],
            "properties": {
              "elements": { "type": "array", "minItems": 2, "items": { "type": "string" } },
              "answer": { "type": "array", "items": { "type": "integer", "minimum": 0 }, "description": "Permutation of element indexes in correct order" }
            }
          }
        },
        {
          "if": { "properties": { "primitive": { "const": "locate" } } },
          "then": {
            "required": ["board", "targets"],
            "properties": {
              "board": { "type": "string", "description": "Board/map asset name" },
              "targets": {
                "type": "array", "minItems": 1,
                "items": {
                  "type": "object", "required": ["label", "x", "y"],
                  "properties": {
                    "label": { "type": "string" },
                    "x": { "type": "number", "minimum": 0, "maximum": 1 },
                    "y": { "type": "number", "minimum": 0, "maximum": 1 },
                    "r": { "type": "number", "exclusiveMinimum": 0, "description": "Acceptance radius, fraction of board width (default 0.05)" }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "primitive": { "const": "argue" } } },
          "then": {
            "required": ["positions"],
            "properties": {
              "positions": { "type": "array", "minItems": 2, "items": { "type": "string" } },
              "evidence": { "type": "array", "items": { "type": "string" }, "description": "Source snippets students may cite" }
            }
          }
        },
        {
          "if": { "properties": { "primitive": { "const": "simulate" } } },
          "then": {
            "required": ["parameters", "model"],
            "properties": {
              "parameters": { "type": "object" },
              "model": { "type": "string", "description": "Reference to a simulation model the shell provides" }
            }
          }
        }
      ]
    }
  }
}
